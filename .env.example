# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=crm_db
DB_USER=crm_user
DB_PASS=crm_pass
MYSQL_ROOT_PASSWORD=rootpassword

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_minimum_32_chars

# App
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# SMTP (platform-level fallback — orgs can override in Settings)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourmail@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=CRM <noreply@yourdomain.com>

# Set to true to seed demo data on first boot
SEED_DB=false

# Frontend (used during Docker build)
REACT_APP_API_URL=http://localhost:5000
