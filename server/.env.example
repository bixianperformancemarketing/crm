NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=crm_db
DB_USER=root
DB_PASSWORD=password

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars

# Client URL (CORS)
CLIENT_URL=http://localhost:3000

# SMTP Configuration (Platform Default)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# Email Identity
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=CRM Platform

# Company Branding (for PDFs and emails)
COMPANY_NAME=Your Company Name
COMPANY_ADDRESS=123 Business Street, City, State 400001
COMPANY_GST=27AABCU9603R1ZX
COMPANY_PHONE=+91 98765 43210
COMPANY_EMAIL=hello@yourcompany.com
COMPANY_WEBSITE=https://yourcompany.com

# Meta Webhook
META_VERIFY_TOKEN=your_meta_verify_token

# WhatsApp Business API
WHATSAPP_VERIFY_TOKEN=your_whatsapp_verify_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_id
WHATSAPP_TOKEN=your_whatsapp_token

# Super Admin Credentials
SUPERADMIN_EMAIL=superadmin@platform.com
SUPERADMIN_PASSWORD=SuperAdmin@123

# File Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
